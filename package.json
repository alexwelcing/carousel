{
  "name": "carousel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/generate-resumes.tsx && vite build",
    "generate:resumes": "TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/generate-resumes.tsx",
    "qa:resume-packets": "TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/validate-resume-packets.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "hf:dev": "npm --prefix hyperframes-studio run dev",
    "hf:check": "PATH=/opt/homebrew/opt/node@22/bin:$PATH npx --yes hyperframes@0.7.3 lint hyperframes-studio && PRODUCER_PUPPETEER_PROTOCOL_TIMEOUT_MS=600000 PRODUCER_PLAYER_READY_TIMEOUT_MS=120000 PATH=/opt/homebrew/opt/node@22/bin:$PATH npx --yes hyperframes@0.7.3 validate hyperframes-studio --timeout 10000 && PRODUCER_PUPPETEER_PROTOCOL_TIMEOUT_MS=600000 PRODUCER_PLAYER_READY_TIMEOUT_MS=120000 PATH=/opt/homebrew/opt/node@22/bin:$PATH npx --yes hyperframes@0.7.3 inspect hyperframes-studio --timeout 8000",
    "hf:render": "PATH=/opt/homebrew/opt/node@22/bin:$PATH npx --yes hyperframes@0.7.3 render hyperframes-studio --low-memory-mode --workers 1 --protocol-timeout 600000 --player-ready-timeout 120000 --output output/hyperframes.mp4",
    "hf:render:docker": "PATH=/opt/homebrew/opt/node@22/bin:$PATH npx --yes hyperframes@0.7.3 render hyperframes-studio --docker --output output/hyperframes.mp4",
    "hf:skills": "PATH=/opt/homebrew/opt/node@22/bin:$PATH npx --yes skills add heygen-com/hyperframes",
    "hf:doctor": "PATH=/opt/homebrew/opt/node@22/bin:$PATH npx --yes hyperframes@0.7.3 doctor",
    "talent:pitch-top30": "PATH=/opt/homebrew/opt/node@22/bin:$PATH TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/generate-pitch-videos.ts --top-targets",
    "talent:pitch-strong": "PATH=/opt/homebrew/opt/node@22/bin:$PATH TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/generate-pitch-videos.ts --strong-fit",
    "talent:pitch-all": "PATH=/opt/homebrew/opt/node@22/bin:$PATH TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/generate-pitch-videos.ts --all",
    "talent:pitch-docker": "PATH=/opt/homebrew/opt/node@22/bin:$PATH TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/generate-pitch-videos.ts --top-targets --docker"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@rive-app/react-canvas": "^4.29.2",
    "@studio-freight/lenis": "^1.0.42",
    "@types/three": "^0.184.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parse": "^7.0.0",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-resizable-panels": "^4.2.2",
    "react-router": "^7.6.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@napi-rs/canvas": "^1.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "plugin-inspect-react-code": "^1.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
